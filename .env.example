# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (from dashboard → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (test-mode keys for dev) ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_STUDIO_PRICE_ID=price_

# --- Resend ---
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=hello@shakebase.co
# Where contact-form submissions are routed; defaults to RESEND_FROM_EMAIL.
CONTACT_INBOX_EMAIL=hello@shakebase.co

# --- App ---
NEXT_PUBLIC_ROOT_DOMAIN=shakebase.co
NEXT_PUBLIC_APP_URL=https://shakebase.co

# --- Dev only (lvh.me resolves *.lvh.me → 127.0.0.1) ---
NEXT_PUBLIC_DEV_ROOT_DOMAIN=lvh.me

# --- Upstash Redis (rate limiter) ---
# Optional in dev — the limiter falls back to an in-memory bucket so local
# flows still work. REQUIRED in prod for multi-instance serverless to share
# state. Create a free Redis at https://upstash.com and copy the REST
# credentials from the "REST API" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
